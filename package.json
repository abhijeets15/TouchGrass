{
  "name": "vibecheck",
  "version": "0.1.0",
  "private": true,
  "main": "apps/mobile/index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=@vibecheck/mobile -- --clear",
    "mobile:device": "bash scripts/start-expo-lan.sh",
    "mobile:tunnel": "npm run start --workspace=@vibecheck/mobile -- --clear --tunnel",
    "web": "npm run dev --workspace=@vibecheck/web",
    "api": "npm run dev --workspace=@vibecheck/api",
    "api:migrate": "npm run migrate --workspace=@vibecheck/api",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "dev:api": "npm run api",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  }
}
